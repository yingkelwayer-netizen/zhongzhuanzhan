{
  "name": "personal-portal",
  "version": "1.0.0",
  "description": "A static personal portal website generated from JSON",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "watch:build": "nodemon --watch config.json --watch build.js --exec \"node build.js\"",
    "watch:serve": "live-server .",
    "dev": "concurrently \"npm run watch:build\" \"npm run watch:serve\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.3"
  }
}
